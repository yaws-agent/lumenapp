{
  "name": "lumen-app",
  "version": "1.0.0",
  "description": "A clean glass interface for slsteam-moon",
  "main": "src/main.js",
  "productName": "Lumen",
  "author": {
    "name": "Hermes",
    "email": "hermessway123@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/yaws-agent/lumenapp",
  "scripts": {
    "start": "electron src/main.js",
    "dist": "electron-builder --linux AppImage",
    "release": "electron-builder --linux AppImage --publish always"
  },
  "build": {
    "appId": "com.yawsagent.lumen",
    "productName": "Lumen",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": "x64"
        }
      ],
      "category": "Utility",
      "maintainer": "Hermes <hermessway123@gmail.com>"
    },
    "publish": {
      "provider": "github",
      "owner": "yaws-agent",
      "repo": "lumenapp",
      "releaseType": "release",
      "vPrefixedTagName": false
    }
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.8.9"
  }
}
